<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="slova" translate="label" sortOrder="300">
            <label>Slova</label>
        </tab>
        <section id="slova_search" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Search</label>
            <tab>slova</tab>
            <resource>Slova_Search::config</resource>

            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <group id="autocomplete" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Autocomplete</label>
                <field id="min_chars" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Minimum Characters</label>
                    <comment>Minimum number of characters before autocomplete triggers.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="max_results" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Maximum Results</label>
                    <comment>Maximum number of autocomplete suggestions to display.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="show_thumbnail" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show Thumbnail</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="show_price" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show Price</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="show_sku" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show SKU</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <group id="opensearch" translate="label" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>OpenSearch</label>
                <field id="edge_ngram_min" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Edge N-Gram Minimum</label>
                    <comment>Minimum length for edge n-gram tokenizer.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
                <field id="edge_ngram_max" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Edge N-Gram Maximum</label>
                    <comment>Maximum length for edge n-gram tokenizer.</comment>
                    <validate>required-entry validate-greater-than-zero validate-digits</validate>
                </field>
            </group>

        </section>
    </system>
</config>
